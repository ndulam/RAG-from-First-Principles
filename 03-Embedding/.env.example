# Copy this file to ".env" in this folder and fill in the values you need.
# Every script here loads this file via python-dotenv's load_dotenv().

# OpenAI - used by 03-LangChain-BM25.py via the non-standard env var names below
# (the script reads O3_API_KEY/O3_BASE_URL rather than OPENAI_API_KEY/OPENAI_BASE_URL)
O3_API_KEY=sk-your-openai-api-key
O3_BASE_URL=https://api.openai.com/v1

# Jina AI embeddings - used by 02-jina-embeddings-v3-clustering.py
JINA_API_KEY=your-jina-api-key
