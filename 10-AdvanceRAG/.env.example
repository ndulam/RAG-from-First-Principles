# Copy this file to ".env" in this folder and fill in the values you need.
# Every script here loads this file via python-dotenv's load_dotenv().
# This is the union of everything needed across all subfolders below.

# OpenAI - used across 02-ContextRetrieval, 04-AgenticRAG, 05-MultiModalRAG
OPENAI_API_KEY=sk-your-openai-api-key

# Cohere - used by 02-ContextRetrieval and 04-AgenticRAG/02-LangChain-AdaptiveRAG.py
# (these scripts use the alternate Cohere env var name)
COHERE_API_KEY=your-cohere-api-key

# Tavily web search - used by 04-AgenticRAG/02-LangChain-AdaptiveRAG.py
TAVILY_API_KEY=tvly-your-tavily-api-key
