# Copy this file to ".env" in this folder and fill in the values you need.
# Every script here loads this file via python-dotenv's load_dotenv().

# OpenAI - used by Milvus-Implementation.py and LlamaIndex-Implementation.py
OPENAI_API_KEY=sk-your-openai-api-key

# Cohere - used by both scripts for reranking (these scripts use the
# alternate Cohere env var name)
COHERE_API_KEY=your-cohere-api-key
