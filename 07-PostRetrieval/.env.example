# Copy this file to ".env" in this folder and fill in the values you need.
# Every script here loads this file via python-dotenv's load_dotenv().
# This is the union of everything needed across all subfolders below.

# OpenAI - used by 01-Reranking, 02-Compression, and 03-Correction scripts
OPENAI_API_KEY=sk-your-openai-api-key

# DeepSeek - used by 01-Reranking/01-RRF-Reranking.py
DEEPSEEK_API_KEY=your-deepseek-api-key

# Cohere - used by 01-Reranking/04-Cohere-Reranking.py and
# 02-Compression/01-ContextualCompressionRetriever-Compression.py
# (these scripts follow the Cohere SDK's own default env var name)
CO_API_KEY=your-cohere-api-key

# Tavily web search - used by 03-Correction/01-CRAG-ReflectiveRetrieval.py
TAVILY_API_KEY=tvly-your-tavily-api-key
