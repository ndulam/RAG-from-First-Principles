# Copy this file to ".env" in this folder and fill in the values you need.
# Every script here loads this file via python-dotenv's load_dotenv().

# OpenAI - used by 05-RankLLM-Reranking.py and 06-RecencyWeightedReranking.py
OPENAI_API_KEY=sk-your-openai-api-key

# DeepSeek - used by 01-RRF-Reranking.py
DEEPSEEK_API_KEY=your-deepseek-api-key

# Cohere - used by 04-Cohere-Reranking.py (follows the Cohere SDK's own
# default env var name)
CO_API_KEY=your-cohere-api-key
