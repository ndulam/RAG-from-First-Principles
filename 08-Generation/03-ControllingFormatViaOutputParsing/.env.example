# Copy this file to ".env" in this folder and fill in the values you need.
# Every script here loads this file via python-dotenv's load_dotenv().

# DeepSeek - used by 01-LangChain-OutputParsing.py, 03-JSON-Output.py,
# 05-function-calling-v1-LangChain.py, and 05-function-calling-v2-DeepSeek.py
DEEPSEEK_API_KEY=your-deepseek-api-key

# OpenAI - used by some of the function-calling/output-parsing examples in this folder
OPENAI_API_KEY=sk-your-openai-api-key
