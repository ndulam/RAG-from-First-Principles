# Copy this file to ".env" in this folder and fill in the values you need.
# Every script here loads this file via python-dotenv's load_dotenv().
# This is the union of everything needed across all subfolders below.

# OpenAI - used by 02-OptimizingResponseViaPrompts and some
# 03-ControllingFormatViaOutputParsing / 04-DynamicGenerationOptimizationStrategies scripts
OPENAI_API_KEY=sk-your-openai-api-key

# DeepSeek - used by most 03-ControllingFormatViaOutputParsing scripts
DEEPSEEK_API_KEY=your-deepseek-api-key
