# Copy this file to ".env" in this folder and fill in the values you need.
# Every script here loads this file via python-dotenv's load_dotenv().

# OpenAI - used by most *_OpenAI*/LlamaIndex examples and 04_LangGraph_RAG.py
OPENAI_API_KEY=sk-your-openai-api-key

# DeepSeek - used by most *_DeepSeek*.py examples
DEEPSEEK_API_KEY=your-deepseek-api-key

# Anthropic Claude - used by 05_RAG_from_Scratch_Claude.py
CLAUDE_API_KEY=your-claude-api-key

# Ollama model name override - used by the *_Ollama.py examples (Ollama itself
# needs no API key, it's a local server)
OLLAMA_MODEL=llama3

# Generic OpenAI-compatible custom endpoint demo - used by
# 01_03_LlamaIndex_SwitchToOpenAICompatibleModel.py
CUSTOM_API_KEY=your-custom-provider-api-key
CUSTOM_API_BASE_URL=https://your-custom-provider/v1
