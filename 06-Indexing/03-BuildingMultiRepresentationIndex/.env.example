
# Copy this file to ".env" and fill in the values you need.
# Only the providers used by the examples you actually run need to be set -
# every script loads this file via python-dotenv's load_dotenv().

# ----------------------------------------------------------------------------
# LLM / Embedding provider keys
# ----------------------------------------------------------------------------

# OpenAI - used across most chapters (00-SimpleRAG, 01-DataLoading, 02-DocChunking,
# 05-PreRetrieval, 06-Indexing, 07-PostRetrieval, 08-Generation, 09-Evaluation, 10-AdvanceRAG)
OPENAI_API_KEY=sk-your-openai-api-key

# Optional: override the OpenAI base URL (used by 07-PostRetrieval/01-Reranking/05-RankLLM-Reranking.py
# to point the rank_llm library at a custom/proxy endpoint)
OPENAI_BASE_URL=https://api.openai.com/v1

# DeepSeek - used across most chapters as the default low-cost chat model
DEEPSEEK_API_KEY=your-deepseek-api-key

# Anthropic Claude - used by 00-SimpleRAG/05_RAG_from_Scratch_Claude.py
CLAUDE_API_KEY=your-claude-api-key

# Cohere - used for reranking. Two different env var names appear in the
# examples because they follow different SDK conventions for the same key:
#   - CO_API_KEY: used by 07-PostRetrieval/01-Reranking/04-Cohere-Reranking.py
#   - COHERE_API_KEY: used by 10-AdvanceRAG/02-ContextRetrieval/*.py
CO_API_KEY=your-cohere-api-key
COHERE_API_KEY=your-cohere-api-key

# Jina AI embeddings - used by 03-Embedding/02-jina-embeddings-v3-clustering.py
JINA_API_KEY=your-jina-api-key

# LlamaCloud / LlamaParse - used by 01-DataLoading/99-Others/15_LlamaParse_PDF*.py
LLAMA_CLOUD_API_KEY=llx-your-llamacloud-api-key

# Tavily web search - used by 10-AdvanceRAG/04-AgenticRAG/02-LangChain-AdaptiveRAG.py
TAVILY_API_KEY=tvly-your-tavily-api-key

# Generic OpenAI-compatible custom endpoint demo - used by
# 00-SimpleRAG/01_03_LlamaIndex_SwitchToOpenAICompatibleModel.py
CUSTOM_API_KEY=your-custom-provider-api-key
CUSTOM_API_BASE_URL=https://your-custom-provider/v1

# ----------------------------------------------------------------------------
# Local model configuration (not secrets, just overrides)
# ----------------------------------------------------------------------------

# Ollama model name override - used by the *_Ollama.py examples in 00-SimpleRAG
OLLAMA_MODEL=llama3

# HuggingFace mirror endpoint - used by 00-SimpleRAG/01_02_LlamaIndex_SwitchEmbeddingModel.py
# to download models from a mirror if huggingface.co is unreachable
HF_ENDPOINT=https://hf-mirror.com

# Model name override - used by the Sakila Text2SQL examples under
# 05-PreRetrieval/01-QueryConstruction/Text2SQL/Sakila/
OPENAI_MODEL=gpt-4o-mini

# ----------------------------------------------------------------------------
# Database / infra connections
# ----------------------------------------------------------------------------

# MySQL (Sakila sample database) - used by 05-PreRetrieval/01-QueryConstruction/Text2SQL/Sakila/01-generate-ddl.py
MYSQL_HOST=localhost
MYSQL_PORT=3306

# Local Milvus database file path - used by the Sakila Text2SQL examples under
# 05-PreRetrieval/01-QueryConstruction/Text2SQL/Sakila/
MILVUS_DB_PATH=./milvus_sakila.db

# Neo4j graph database password - used by 05-PreRetrieval/01-QueryConstruction/Text2Cypher/*.py
NEO4J_PASSWORD=your-neo4j-password
