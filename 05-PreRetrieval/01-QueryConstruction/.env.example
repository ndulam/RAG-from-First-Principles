# Copy this file to ".env" in this folder and fill in the values you need.
# Every script here loads this file via python-dotenv's load_dotenv().

# OpenAI - used by the Sakila Text2SQL scripts and 02-Text2SQL-LLM-OpenAI.py
OPENAI_API_KEY=sk-your-openai-api-key

# DeepSeek - used by 02-Text2SQL-LLM-DeepSeek.py, BuildingMetadataFilter, and
# Text2Cypher scripts
DEEPSEEK_API_KEY=your-deepseek-api-key

# Model name override - used by the Sakila Text2SQL agent scripts under Text2SQL/Sakila/
OPENAI_MODEL=gpt-4o-mini

# MySQL (Sakila sample database) - used by Text2SQL/Sakila/01-generate-ddl.py
MYSQL_HOST=localhost
MYSQL_PORT=3306

# Local Milvus database file path - used by the Sakila Text2SQL agent scripts
MILVUS_DB_PATH=./milvus_sakila.db

# Neo4j graph database password - used by Text2Cypher/*.py
NEO4J_PASSWORD=your-neo4j-password
