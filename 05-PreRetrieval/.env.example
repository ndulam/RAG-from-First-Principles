# Copy this file to ".env" in this folder and fill in the values you need.
# Every script here loads this file via python-dotenv's load_dotenv().
# This is the union of everything needed across all subfolders below.

# OpenAI - used by 03-QueryRouting/02-SemanticRouting.py and the Sakila Text2SQL scripts
OPENAI_API_KEY=sk-your-openai-api-key

# DeepSeek - used across 01-QueryConstruction, 02-QueryTranslation, 03-QueryRouting
DEEPSEEK_API_KEY=your-deepseek-api-key

# Model name override - used by the Sakila Text2SQL agent scripts under
# 01-QueryConstruction/Text2SQL/Sakila/
OPENAI_MODEL=gpt-4o-mini

# MySQL (Sakila sample database) - used by
# 01-QueryConstruction/Text2SQL/Sakila/01-generate-ddl.py
MYSQL_HOST=localhost
MYSQL_PORT=3306

# Local Milvus database file path - used by the Sakila Text2SQL agent scripts
MILVUS_DB_PATH=./milvus_sakila.db

# Neo4j graph database password - used by
# 01-QueryConstruction/Text2Cypher/*.py
NEO4J_PASSWORD=your-neo4j-password
