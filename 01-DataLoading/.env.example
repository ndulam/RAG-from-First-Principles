# Copy this file to ".env" in this folder and fill in the values you need.
# Every script here loads this file via python-dotenv's load_dotenv().
# This is the union of everything needed across all subfolders below.

# OpenAI - used by 03-ParsingImageAndTextData and 05-TableDataLoading scripts
OPENAI_API_KEY=sk-your-openai-api-key

# LlamaCloud / LlamaParse - used by 04-PDFFileLoading, 05-TableDataLoading,
# and 99-Others LlamaParse scripts
LLAMA_CLOUD_API_KEY=llx-your-llamacloud-api-key
